# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
# Create an API key in AI Studio and paste it below.
GEMINI_API_KEY=

# Model from AI Studio (examples: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro)
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3

# Alternative env name (same key as GEMINI_API_KEY)
# LLM_API_KEY=

# Recommendation limits
MAX_CANDIDATES=30
TOP_N=5

# Data pipeline
DATA_PATH=data/processed/restaurants.parquet
FORCE_REFRESH=false
LOG_LEVEL=INFO
